# =============================================================================
# Yardie AI Platform - Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values before running docker compose up.
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
# Username for the PostgreSQL superuser
POSTGRES_USER=postgres

# Password for the PostgreSQL superuser (CHANGE THIS)
POSTGRES_PASSWORD=change-me-to-a-strong-password

# -----------------------------------------------------------------------------
# Portal (Next.js)
# -----------------------------------------------------------------------------
# Secret key used by Better Auth for signing sessions and tokens (CHANGE THIS)
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=change-me-to-a-random-secret

# Resend API key for transactional email (signup verification, password reset)
# Get one at https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Public URL of the portal (used for links in emails and OAuth callbacks)
NEXT_PUBLIC_APP_URL=http://localhost

# -----------------------------------------------------------------------------
# LiteLLM Proxy
# -----------------------------------------------------------------------------
# Master key for the LiteLLM Admin API (CHANGE THIS)
# Generate with: openssl rand -hex 16
LITELLM_MASTER_KEY=sk-litellm-master-key-change-me

# OpenRouter API key for LLM requests
# Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# LiteLLM base URL (for portal provisioning code)
# Docker: http://litellm:4000 | Local dev: http://localhost:4000
LITELLM_BASE_URL=http://localhost:4000

# -----------------------------------------------------------------------------
# OpenWebUI Test Instance
# -----------------------------------------------------------------------------
# LiteLLM API key for the test OpenWebUI instance
OPENWEBUI_TEST_API_KEY=sk-test-instance-key

# Secret key for OpenWebUI session signing (CHANGE THIS)
# Generate with: openssl rand -base64 32
OPENWEBUI_TEST_SECRET=openwebui-test-secret
